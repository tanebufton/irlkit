# ─────────────────────────────────────────────────────────────────────────────
# irlkit configuration — copy to .env and fill in. install.sh generates this.
# ─────────────────────────────────────────────────────────────────────────────

# Public hostname you point at this box (A/AAAA record). Caddy gets a TLS cert
# for it automatically. Use the server's IP for a cert-less local test.
IRLKIT_DOMAIN=irl.example.com

# Email for Let's Encrypt expiry notices (optional but recommended).
ACME_EMAIL=me@example.com

# ── Auth ─────────────────────────────────────────────────────────────────────
# Owner login for the studio + remote control panel. Change these.
OWNER_USERNAME=owner
OWNER_PASSWORD=change-me-now
# Secret used to sign session cookies + scoped operator tokens. 64+ random chars.
# install.sh generates this with `openssl rand -hex 32`.
SESSION_SECRET=replace-with-openssl-rand-hex-32

# ── Ingest ───────────────────────────────────────────────────────────────────
# Stream key a publisher must include (RTMP path / SRT streamid) to be accepted.
# Keeps randoms off your ingest. install.sh randomizes it.
STREAM_KEY=changeme

# Public UDP port for SRTLA bonded ingest (BELABOX / IRL Pro bonded cellular).
SRTLA_PORT=5000
# Public UDP port for single-link plain SRT ingest.
SRT_PORT=4001
# Public TCP port for RTMP ingest.
RTMP_PORT=1935

# ── OBS encoder defaults (studio UI can override live) ───────────────────────
# low-cpu | balanced | quality  — maps to x264 preset + bitrate below.
ENCODER_PRESET=balanced
OUTPUT_WIDTH=1920
OUTPUT_HEIGHT=1080
OUTPUT_FPS=60
OUTPUT_BITRATE_KBPS=6000

# ── Stream destination (where OBS sends the finished program) ────────────────
# Full RTMP URL incl. app, e.g. rtmp://live.twitch.tv/app  (leave key separate).
DEST_RTMP_URL=
DEST_STREAM_KEY=

# ── Internal (rarely change) ─────────────────────────────────────────────────
OBS_WS_PASSWORD=replace-with-openssl-rand-hex-16
API_PORT=3000
TZ=UTC
